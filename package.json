{
  "name": "readme",
  "productName": "readme",
  "version": "0.1.0",
  "description": "Local-first long text to AI narrated MP3 app",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:keychain-helper && npm run build:main && vite --host 127.0.0.1",
    "dev:electron": "VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build:keychain-helper": "mkdir -p dist/native && clang -fobjc-arc -framework Foundation -framework Security src/native/keychain-helper.m -o dist/native/longread-keychain",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:keychain-helper && npm run build:main && npm run build:renderer",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.config.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "ffmpeg-static": "^5.2.0",
    "jsdom": "^24.1.3",
    "openai": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0 <22.0.0"
  }
}
